{
  "info": {
    "name": "API Livros Completa",
    "_postman_id": "abc123-collection",
    "description": "Collection com autenticação JWT, autores e livros",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://project-api-c2pu.onrender.com"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuario\": \"admin\",\n  \"senha\": \"123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/login",
          "host": ["{{base_url}}"],
          "path": ["login"]
        }
      }
    },
    {
      "name": "Criar Autor",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Machado de Assis\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/autores",
          "host": ["{{base_url}}"],
          "path": ["api", "autores"]
        }
      }
    },
    {
      "name": "Listar Autores",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/autores",
          "host": ["{{base_url}}"],
          "path": ["api", "autores"]
        }
      }
    },
    {
      "name": "Criar Livro",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Dom Casmurro\",\n  \"genero\": \"Clássico\",\n  \"ano\": 1899,\n  \"autor_id\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/livros",
          "host": ["{{base_url}}"],
          "path": ["api", "livros"]
        }
      }
    },
    {
      "name": "Listar Livros",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/livros?page=1&limit=5",
          "host": ["{{base_url}}"],
          "path": ["api", "livros"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "5" }
          ]
        }
      }
    },
    {
      "name": "Buscar Livro por ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/livros/1",
          "host": ["{{base_url}}"],
          "path": ["api", "livros", "1"]
        }
      }
    },
    {
      "name": "Atualizar Livro",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Dom Casmurro Atualizado\",\n  \"genero\": \"Clássico\",\n  \"ano\": 1900,\n  \"autor_id\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/livros/1",
          "host": ["{{base_url}}"],
          "path": ["api", "livros", "1"]
        }
      }
    },
    {
      "name": "Deletar Livro",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/livros/1",
          "host": ["{{base_url}}"],
          "path": ["api", "livros", "1"]
        }
      }
    }
  ]
}
